WC_HUB_ENV=development
WC_HUB_HTTP_ADDR=:8080
WC_HUB_PUBLIC_URL=http://localhost:5173
WC_HUB_API_URL=http://localhost:8080
WC_HUB_DATABASE_URL=postgres://wc_hub:change-me@postgres:5432/wc_hub?sslmode=disable
WC_HUB_DB_MAX_CONNS=20
WC_HUB_LOG_LEVEL=info
WC_HUB_ENCRYPTION_KEY=replace-with-32-byte-base64-key
WC_HUB_JWT_SECRET=replace-with-at-least-32-random-characters
WC_HUB_TOTP_ISSUER=WC Hub
WC_HUB_SESSION_TTL=12h
WC_HUB_SECURE_COOKIES=false
WC_HUB_LOCAL_TARGET_NAME=wc-hub-local
WC_HUB_SELF_PROTECTED=true
WC_HUB_LOCAL_COMMAND_ALLOWLIST=uptime,df,free,ip,ss,journalctl,docker,kubectl

# Integrations (leave blank until configured through encrypted settings)
PROXMOX_API_URL=
PROXMOX_API_TOKEN_ID=
PROXMOX_API_TOKEN_SECRET=
PROXMOX_TLS_CA_PATH=/run/secrets/proxmox_ca.pem
DOCKER_PROXY_URL=
DOCKER_TLS_CA_PATH=/run/secrets/docker_ca.pem
DOCKER_CLIENT_CERT_PATH=/run/secrets/docker_client.pem
DOCKER_CLIENT_KEY_PATH=/run/secrets/docker_client_key.pem
GITHUB_TOKEN=
GITHUB_REPOSITORY_ALLOWLIST=
TERRAFORM_WORKER_URL=
TERRAFORM_WORKER_TOKEN=
TERRAFORM_WORKSPACE_ALLOWLIST=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ALLOWLIST=
CLOUDFLARE_ZONE_ALLOWLIST=
KUBECONFIG_PATH=/run/secrets/kubeconfig
KUBERNETES_API_URL=
KUBERNETES_TOKEN_PATH=/run/secrets/kubernetes_service_account_token
KUBERNETES_CA_PATH=/run/secrets/kubernetes_ca.pem
MERGERFS_ROOT=/mnt/drive
SSH_KNOWN_HOSTS_PATH=/run/secrets/ssh_known_hosts
WC_HUB_SSH_PRIVATE_KEY_PATH=/run/secrets/ssh_private_key
WC_HUB_SSH_KNOWN_HOSTS_PATH=/run/secrets/ssh_known_hosts
WC_HUB_WORKER_COUNT=2
WC_HUB_WORKER_ID=wc-hub-1
WC_AGENT_TOKEN=
WC_AGENT_INTERVAL=15s
WC_AGENT_SELF_PROTECTED=true
DCGM_EXPORTER_URL=http://dcgm-exporter:9400/metrics
